# ============================================================
# SmartResearch 环境配置模板
# 复制此文件为 .env 并填入你的 API Key
# 你可以在 4 种 LLM 提供商中自由选择
# 桌面端「编辑 → 设置」中也可以直接切换
# ============================================================

# ==================== LLM 提供商选择 ====================
# 可选值: deepseek（推荐）| openai | claude | custom
LLM_PROVIDER=deepseek


# ==================== 方式一：DeepSeek（推荐）====================
# 中文能力强、价格低、兼容 OpenAI API
# 注册: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat


# ==================== 方式二：OpenAI ====================
# 切换到 openai 时需要去掉下面注释并将 LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o


# ==================== 方式三：Anthropic Claude ====================
# 切换到 claude 时需要去掉下面注释并将 LLM_PROVIDER=claude
# 需安装: pip install langchain-anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514


# ==================== 方式四：自定义 OpenAI 兼容 API ====================
# 支持 Groq / Together AI / vLLM / Ollama 等
# 切换到 custom 时需要去掉下面注释并将 LLM_PROVIDER=custom
# CUSTOM_API_KEY=sk-...
# CUSTOM_API_BASE=https://api.openai.com/v1
# CUSTOM_MODEL=gpt-4o-mini


# ==================== Embedding（向量化，独立配置）====================
# 桌面版默认关闭本地 Embedding（避免加载 TensorFlow 拖慢启动）
# 需要语义搜索时改为 True（首次启动自动下载模型）
USE_LOCAL_EMBEDDING=False
EMBEDDING_MODEL=text-embedding-3-small


# ==================== 其他配置（一般保持默认）====================
APP_ENV=development
DEBUG=True
UPLOAD_DIR=./data/uploads
CHROMA_DB_PATH=./data/chroma

# Neo4j（不配置不影响使用，仅图谱功能禁用）
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
