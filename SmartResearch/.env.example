# ============================================================
# SmartResearch 环境配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# ==================== 必需配置 ====================
# DeepSeek API Key（用于 AI 对话、摘要、实体提取）
# 注册获取: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ==================== 可选配置 ====================

# DeepSeek API 地址（一般不需要修改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI Key（仅用于 Embedding，不是必需）
# 如果留空且 USE_LOCAL_EMBEDDING=False，将自动使用本地 TF-IDF
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# 本地 Embedding（设为 True 使用 HuggingFace 模型，首次运行需下载）
# USE_LOCAL_EMBEDDING=False

# Neo4j 配置（不启动不影响使用，仅图谱功能禁用）
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
