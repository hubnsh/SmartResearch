# ========== 必填：DeepSeek API（对话 / 摘要 / 提取）==========
DEEPSEEK_API_KEY=your_deepseek_api_key

# ========== 必选其一：Embedding（向量化用）==========
# A) OpenAI 兼容 API
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_API_BASE=https://api.openai.com/v1
# B) 本地 HuggingFace 模型（无需联网，把下面设为 True 并删除上面的 OPENAI_API_KEY）
USE_LOCAL_EMBEDDING=True

# ========== Neo4j（本地 Docker，默认值即可）==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ========== ChromaDB（本地，默认值即可）==========
CHROMA_DB_PATH=./data/chroma

# ========== 可选 ==========
# REDIS_URL=redis://localhost:6379/0
# NOTION_TOKEN=your_notion_integration_token

APP_ENV=development
DEBUG=True
UPLOAD_DIR=./data/uploads




# ========== 本地缓存路径（D盘）==========
HF_HOME=D:/github_demo/SmartResearch/data/huggingface
HUGGINGFACE_HUB_CACHE=D:/github_demo/SmartResearch/data/huggingface

# CHROMA_SERVER_URL=http://localhost:8000  # docker-compose ChromaDB service
